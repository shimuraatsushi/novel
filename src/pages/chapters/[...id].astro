---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const chapters = await getCollection('chapters');
  return chapters.map((chapter) => ({
    params: { id: chapter.id.replace(/\.md$/, '') },
    props: { chapter },
  }));
}

const { chapter } = Astro.props;
const { Content } = await render(chapter);

// 前後の話を取得
const allChapters = await getCollection('chapters');
const sorted = allChapters
  .filter((c) => c.data.part === chapter.data.part)
  .sort((a, b) => a.data.episode - b.data.episode);

const currentIndex = sorted.findIndex((c) => c.id === chapter.id);
const prevChapter = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextChapter = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const partNames: Record<number, string> = {
  1: '第一部',
  2: '第二部',
  3: '第三部',
};
---

<Layout
  title={`第${chapter.data.episode}話「${chapter.data.title}」`}
  description={chapter.data.description}
>
  <article class="chapter-page">
    <header class="chapter-header">
      <p class="chapter-part">{partNames[chapter.data.part]}</p>
      <p class="chapter-num">第{chapter.data.episode}話</p>
      <h1 class="chapter-title">「{chapter.data.title}」</h1>
      <div class="chapter-ornament">━━━◆━━━</div>
    </header>

    <div class="chapter-body">
      <Content />
    </div>

    <footer class="chapter-footer">
      <div class="chapter-ornament">━━━◆━━━</div>
      <nav class="chapter-nav">
        <div class="nav-prev">
          {prevChapter && (
            <a href={`/chapters/${prevChapter.id.replace(/\.md$/, '')}/`} class="nav-link nav-link--prev">
              <span class="nav-label">◀ 前の話</span>
              <span class="nav-title">第{prevChapter.data.episode}話「{prevChapter.data.title}」</span>
            </a>
          )}
        </div>
        <div class="nav-home">
          <a href="/" class="nav-link nav-link--home">目次へ</a>
        </div>
        <div class="nav-next">
          {nextChapter && (
            <a href={`/chapters/${nextChapter.id.replace(/\.md$/, '')}/`} class="nav-link nav-link--next">
              <span class="nav-label">次の話 ▶</span>
              <span class="nav-title">第{nextChapter.data.episode}話「{nextChapter.data.title}」</span>
            </a>
          )}
        </div>
      </nav>
    </footer>
  </article>
</Layout>
